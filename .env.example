# === 数据库 ===
# 开发: sqlite+aiosqlite:///./dev.db
# MySQL: mysql+aiomysql://root:pass@localhost:3306/windemiko_dev
# PostgreSQL: postgresql+asyncpg://user:pass@localhost:5432/windemiko_dev
DATABASE_URL=sqlite+aiosqlite:///./dev.db

# === JWT ===
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# === 文件上传 ===
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=524288000
AVATAR_MAX_SIZE=2097152

# === LLM (预留，暂不集成) ===
OLLAMA_BASE_URL=http://localhost:11434
LLM_BACKEND=none

# === CORS ===
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# === 应用 ===
APP_NAME=WindEmiko Portal
DEBUG=true

# ============================================================
# FwindEmiko-Web · 生产环境变量模板
# 复制为 .env.prod 并填入真实值（.env.prod 不进 Git！）
# ============================================================

# === 数据库（容器内通信，host=fwe-db）===
DATABASE_URL=mysql+aiomysql://windemiko:***@fwe-db:3306/windemiko

# === Docker Compose 变量 ===
DB_ROOT_PASSWORD=YOUR_DB_ROOT_PASSWORD

# === JWT ===
JWT_SECRET=YOUR_JWT_SECRET_KEY
# === 文件上传 ===
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=524288000
AVATAR_MAX_SIZE=2097152

# === LLM（预留）===
OLLAMA_BASE_URL=http://localhost:11434
LLM_BACKEND=none

# === CORS ===
CORS_ORIGINS=["https://f.windemiko.top","http://localhost:4173"]

# === 应用 ===
APP_NAME=WindEmiko Portal
DEBUG=false

# === 注册默认角色 ===
# 通过 /auth/register 接口创建的新用户的默认角色
# 可选值: member / author / moderator（admin 不能通过注册接口创建）
REGISTER_DEFAULT_ROLE=member
